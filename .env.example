# Copy to .env and fill in. .env is gitignored.

# Google OAuth (https://console.cloud.google.com → Credentials)
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NUXT_GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
NUXT_PUBLIC_APP_URL=http://localhost:8788
NUXT_SESSION_SECRET=change-this-to-a-long-random-secret

# Penalty tuning
NUXT_PUBLIC_PENALTY_HOURS_PER_QUARTER=1.5
NUXT_PUBLIC_MAYO_PENALTY_HOURS=1
NUXT_PUBLIC_SOFT_DRINK_PENALTY_HOURS=2

# Cloudflare D1 — wrangler.toml interpolates this via ${CLOUDFLARE_D1_DATABASE_ID}.
# Needed only for `npm run deploy`. Local dev uses the preview (local) DB.
CLOUDFLARE_D1_DATABASE_ID=your-cloudflare-d1-database-id
